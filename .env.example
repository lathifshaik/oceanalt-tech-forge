# ── Gemini AI ──────────────────────────────────────────────
# Required for the AI Concierge chatbot.
# Get it from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# ── EmailJS ─────────────────────────────────────────────────
# Required for email notifications when a lead submits the form or the chatbot.
# Setup steps:
#   1. Create a free account at https://www.emailjs.com
#   2. Add a service (Gmail recommended — connect hello@oceanalt.com.au)
#   3. Create a template with these variables:
#        {{lead_name}}, {{lead_email}}, {{lead_company}},
#        {{lead_budget}}, {{lead_project_type}}, {{lead_message}}, {{lead_source}}
#   4. Copy the Service ID, Template ID, and Public Key below.
EMAILJS_SERVICE_ID="service_xxxxxxx"
EMAILJS_TEMPLATE_ID="template_xxxxxxx"
EMAILJS_PUBLIC_KEY="xxxxxxxxxxxxxxxxxxxx"

# ── Firebase ────────────────────────────────────────────────
# Used by the lead-capture form and chatbot to write to Firestore.
# Note: Firebase web API keys are public identifiers, NOT secrets — they
# ship in the client bundle by design. Real security comes from:
#   1. Firestore Security Rules gating the `leads` collection
#   2. HTTP referrer restrictions on the key (GCP Console → APIs & Services
#      → Credentials → edit key → set allowed referrers to your prod domain)
#   3. Optional App Check (reCAPTCHA Enterprise) for abuse prevention
# Get these values from Firebase Console → Project Settings → Your apps.
FIREBASE_API_KEY="AIzaSy..."
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_APP_ID="1:1234567890:web:abcdef"
FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"
FIREBASE_STORAGE_BUCKET="your-project-id.firebasestorage.app"
FIREBASE_MESSAGING_SENDER_ID="1234567890"
# Leave as "(default)" unless you created a named Firestore database.
FIREBASE_FIRESTORE_DATABASE_ID="(default)"

# ── App URL ─────────────────────────────────────────────────
APP_URL="http://localhost:3000"
