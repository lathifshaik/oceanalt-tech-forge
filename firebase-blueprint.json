{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "A potential client lead captured via the AI bot.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "query": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "chatHistory": { "type": "string" }
      },
      "required": ["query", "timestamp"]
    }
  },
  "firestore": {
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "Collection of leads captured by the AI bot."
    }
  }
}
